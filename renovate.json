{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "docker:enableMajor"],
  "commitMessagePrefix": ":rocket:",
  "prConcurrentLimit": 32,
  "packageRules": [
    {
      "updateTypes": ["patch"],
      "commitMessagePrefix": ":adhesive_bandage:"
    },
    {
      "updateTypes": ["major"],
      "commitMessagePrefix": ":boom:"
    },
    {
      "matchPackageNames": ["alpine"],
      "matchDatasources": ["docker"],
      "sourceUrl": "https://alpinelinux.org/releases/"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Docker image versions in YAML label fields",
      "fileMatch": [
        "\\.ya?ml$"
      ],
      "matchStrings": [
        ":\\s*docker://(?<depName>[^:]+):(?<currentValue>[^\\s\"']+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ]
}